# ---------------------------------------------------------------------------
# Build artifacts
# ---------------------------------------------------------------------------

# Object files and dependency files (C userspace — legacy)
*.o
*.d

# ELF binaries at repo root (generated by make)
bazzulto.elf

# ELF placed in the ESP boot partition
esp/bazzulto.elf

# Disk images (generated by mkfs_btrfs / mkfatimg / Makefile)
disk.img
disk2.img

# ---------------------------------------------------------------------------
# Rust
# ---------------------------------------------------------------------------

# Cargo build output — kernel
kernel/target/

# Cargo build output — unified userspace workspace
userspace/target/

# Cargo build output — all BSL library crates (includes rustdoc HTML under target/doc/)
userspace/libraries/**/target/


# Cargo build output — mkfs_btrfs host tool
tools/mkfs_btrfs/target/

# Compiled IANA TZif binaries — generated at build time from third_party/tz
third_party/zoneinfo/

# ---------------------------------------------------------------------------
# Documentation — generated output
# ---------------------------------------------------------------------------

# MkDocs generated site (do not commit; deploy via CI or manually)
site/

# MkDocs directory — generated output and config, not tracked
docs/mkdocs/

# Wiki is tracked as a git submodule (GitHub Wiki)
# docs/wiki/

# Reference PDFs — large binary files, not tracked in git
docs/*.pdf

docs/posix-spec

# MkDocs Python virtualenv / dependencies
docs/requirements.txt.lock

# ---------------------------------------------------------------------------
# QEMU / debug logs
# ---------------------------------------------------------------------------

uart.log
qemu_debug.log

# ---------------------------------------------------------------------------
# Editor and IDE files
# ---------------------------------------------------------------------------

.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Agent and AI tooling
# ---------------------------------------------------------------------------

.mcp.json
invocation_reasons.yaml
.qwen/
.claude/

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------

__pycache__/
*.pyc
*.pyo
.venv/

# ---------------------------------------------------------------------------
# Secrets / local config (never commit)
# ---------------------------------------------------------------------------

.env
*.pem
*.key
.api_docs_stamp
