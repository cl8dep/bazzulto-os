/* -----------------------------------------------------------------------
 * Section 4 — Redirects for unimplemented Linux-numbered syscalls
 *
 * These map Linux aarch64 syscall numbers to valid Bazzulto entries when
 * the semantics are close enough, or to an unused slot (→ ENOSYS/EINVAL)
 * when there is no reasonable fallback.
 * ----------------------------------------------------------------------- */

/* stat / lstat: no separate path-based stat; use fstatat (AT_FDCWD + path) */
#define __NR_stat               121
#define __NR_lstat              121

/* symlinkat: Bazzulto has no dirfd form yet; fallback to symlink */
#define __NR_symlinkat          140
/* linkat: same situation */
#define __NR_linkat             141

/* faccessat: AT_FDCWD + path behaves like access */
#define __NR_faccessat          130
#define __NR_faccessat2         130

/* mkfifoat: no dirfd form; falls back to mkfifo */
#define __NR_mkfifoat           71

/* sync / syncfs → fsync */
#define __NR_sync               59
#define __NR_syncfs             59
#define __NR_sync_file_range    59

/* preadv / pwritev → pread64 / pwrite64 (single-iov fast path) */
#define __NR_preadv             149
#define __NR_pwritev            150
#define __NR_preadv2            149
#define __NR_pwritev2           150

/* rt_sigtimedwait / rt_sigqueueinfo: no implementation; map to unused slot */
#define __NR_rt_sigtimedwait    162
#define __NR_rt_sigqueueinfo    162
#define __NR_rt_tgsigqueueinfo  162

/* waitpid: musl uses wait4; map there */
#define __NR_waitpid            9

/* timerfd: not implemented */
#define __NR_timerfd_create     162
#define __NR_timerfd_settime    162
#define __NR_timerfd_gettime    162

/* signalfd4: not implemented */
