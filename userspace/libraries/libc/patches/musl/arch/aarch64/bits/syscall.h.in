#define __NR_rt_sigsuspend      45
#define __NR_getrusage          46
#define __NR_prctl              47
#define __NR_gettimeofday       48
/* poll: Bazzulto 49, struct layout matches Linux {i32 fd; u16 events; u16 revents} */
#define __NR_ppoll              49
#define __NR_getuid             50
#define __NR_getgid             51
#define __NR_chdir              52
#define __NR_getcwd             53
#define __NR_mkdir              54
