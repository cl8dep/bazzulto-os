#define __NR_creat              24
#define __NR_unlink             25
#define __NR_fstat              26
/* 27 = setfgpid     (Bazzulto-specific) */
/* 28 = disk_info    (Bazzulto-specific) */
#define __NR_getrandom          29
#define __NR_nice               30
#define __NR_getpriority        31
#define __NR_setpriority        32
#define __NR_getrlimit          33
#define __NR_setrlimit          34
/* prlimit64: musl calls this; map to setrlimit (soft limit used, hard ignored) */
#define __NR_prlimit64          34
#define __NR_getpgrp            35
#define __NR_setpgid            36
#define __NR_getsid             37
#define __NR_setsid             38
#define __NR_tcgetpgrp          39
#define __NR_tcsetpgrp          40
