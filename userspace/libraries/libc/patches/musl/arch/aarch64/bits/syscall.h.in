/* Bazzulto OS — AArch64 syscall numbers
 *
 * These replace the Linux aarch64 numbers that musl ships with.
 * ABI is identical: x8 = syscall number, x0–x5 = arguments, x0 = return value.
 *
 * Source of truth: kernel/src/systemcalls/mod.rs (pub mod numbers)
 *
 * Sections:
 *   1. Core syscalls (0–114)        — original Bazzulto-numbered syscalls
 *   2. musl bootstrap (115–119)     — set_tid_address, set_robust_list, etc.
 *   3. POSIX *at + new (120–161)    — musl ABI alignment additions
 *   4. Redirects for unimplemented  — map Linux-numbered calls that musl may
 *                                     invoke to the nearest working equivalent
 *                                     or to an unused slot (→ ENOSYS/-EINVAL)
 */

/* -----------------------------------------------------------------------
 * Section 1 — Core syscalls (0–114)
 * ----------------------------------------------------------------------- */

#define __NR_exit               0
#define __NR_write              1
#define __NR_read               2
#define __NR_sched_yield        3
#define __NR_open               4
#define __NR_close              5
#define __NR_lseek              6
/* 7  = spawn   (Bazzulto-specific) */
/* 8  = list    (Bazzulto-specific) */
#define __NR_wait4              9
#define __NR_pipe               10
#define __NR_dup                11
#define __NR_dup2               12
#define __NR_mmap               13
#define __NR_munmap             14
#define __NR_fork               15
/* vfork → fork; no copy-on-write yet */
#define __NR_vfork              15
#define __NR_execve             16
#define __NR_getpid             17
#define __NR_getppid            18
#define __NR_clock_gettime      19
#define __NR_nanosleep          20
